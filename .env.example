# Copy to .env and fill in values. Never commit .env.

# LLM keys (optional — enables smarter extraction in agent)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Evidence agent API (required for Lovable live connection)
AGENT_API_KEY=generate-a-long-random-string-here
AGENT_PORT=8765
AGENT_HOST=0.0.0.0

# After starting ngrok: ngrok http 8765 → paste HTTPS URL here
AGENT_PUBLIC_URL=https://your-subdomain.ngrok-free.app

# Comma-separated CORS origins (use * for dev, or your Lovable preview URL)
CORS_ORIGINS=*
